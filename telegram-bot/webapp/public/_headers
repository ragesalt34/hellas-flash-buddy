# Baseline security headers for every page
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Hashed build assets — safe to cache forever (filename changes on rebuild)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# UI sound effects — a week-long cache here meant a swapped sound file could
# stay stale on the edge for 7 days after deploy (hit this in July 2026: a new
# tap.mp3 didn't take effect on hellas.study while pages.dev was already
# fresh). Short cache instead; sound.ts also cache-busts via ?v= on top of this.
/sounds/*
  Cache-Control: public, max-age=300

/icon.png
  Cache-Control: public, max-age=86400
