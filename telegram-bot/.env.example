# --- Обязательные ---
SUPABASE_URL=          # https://<новый-проект>.supabase.co
SUPABASE_SERVICE_KEY=  # service_role ключ нового проекта (НЕ anon!)
APP_SECRET=            # любая длинная случайная строка — подписывает токены сессий и гостевой доступ

# --- Необязательные ---
API_PORT=3001          # локальный порт (на Render порт задаёт сам хостинг через PORT)
GOOGLE_TTS_API_KEY=    # для озвучки греческих слов (можно оставить пустым)
GOOGLE_TTS_VOICE=      # напр. el-GR-Wavenet-A (по умолчанию подставляется)
